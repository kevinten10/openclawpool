# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Service
GLM_API_KEY=your-zhipuai-api-key

# CORS Configuration (comma-separated list)
# Defaults: http://localhost:3000, https://openclawpool.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://openclawpool.vercel.app

# Rate Limiting (optional)
# Default values are set in code, but can be overridden
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
